# Suvy environment configuration
# Copy this file to .env and adjust values for your deployment.

# Server
PORT=8800
SITE_URL=http://localhost:8800

# DuvyCrawler API endpoint
CRAWLER_API=http://localhost:8080/api/v1

# DuckDuckGo fallback
DDG_ENABLED=true
DDG_RESULTS=3
DDG_CACHE_TTL_MINUTES=120

# UI settings
NEWS_MAX_ITEMS=5
WIKIPEDIA_CARD_ENABLED=true
RESULTS_PER_PAGE=10
DEFAULT_LANG=es
