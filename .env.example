# ─── Cloudflare ─────────────────────────────
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ─── General ────────────────────────────────
TZ=UTC

# ─── Network / Ports (only used if exposed) ─
APP_PORT=8800

# ─── URLs ───────────────────────────────────
SITE_URL=https://search.example.domain
CRAWLER_API=http://duvycrawl:8080/api/v1

# ─── Proxy ──────────────────────────────────
PROXY_URL=socks5://warp:1080

# ─── DuckDuckGo fallback ────────────────────
DDG_ENABLED=true
DDG_RESULTS=3
DDG_CACHE_TTL_MINUTES=120

# ─── UI Settings ────────────────────────────
NEWS_MAX_ITEMS=5
WIKIPEDIA_CARD_ENABLED=true
RESULTS_PER_PAGE=10
DEFAULT_LANG=en