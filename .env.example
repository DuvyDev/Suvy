# ─── Cloudflare ─────────────────────────────
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ─── General ────────────────────────────────
TZ=UTC

# ─── Network / Ports (only used if exposed) ─
APP_PORT=8800

# ─── URLs ───────────────────────────────────
SITE_URL=https://search.example.domain
CRAWLER_API=http://duvycrawl:8080/api/v1

# ─── Proxy ──────────────────────────────────
PROXY_URL=socks5://warp:1080

# ─── DuckDuckGo fallback ────────────────────
DDG_ENABLED=true
DDG_RESULTS=3
DDG_CACHE_TTL_MINUTES=120

# ─── UI Settings ────────────────────────────
NEWS_MAX_ITEMS=5
WIKIPEDIA_CARD_ENABLED=true
WIKIPEDIA_USE_API=true
WIKIPEDIA_TIMEOUT_MS=4000
WIKIPEDIA_MAX_RETRIES=2
RESULTS_PER_PAGE=10
DEFAULT_LANG=en

# ─── Map Card (interactive with MapTiler) ─────────────────────────────
MAP_CARD_ENABLED=true
MAP_TILER_ENABLED=true
MAP_TILER_API_KEY=your_maptiler_api_key_here
NOMINATIM_CACHE_TTL_DAYS=30
NOMINATIM_TIMEOUT_MS=4000