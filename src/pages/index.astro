---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import LanguageToggle from '../components/LanguageToggle.astro';
import { getTranslation } from '../i18n/translations';

const langCookie = Astro.cookies.get('lang')?.value;
const t = getTranslation(langCookie);
---

<Layout title="Search">
  <main class="flex-1 flex flex-col justify-center items-center px-4 w-full h-[calc(100vh-80px)]">
    
    <!-- Logo -->
    <div class="mb-10 animate-fade-in-up">
      <h1 class="text-7xl sm:text-9xl font-extrabold tracking-tighter text-center pb-4" style="background: -webkit-linear-gradient(45deg, #4285F4, #EA4335, #FBBC05, #34A853); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        Search
      </h1>
    </div>

    <!-- Search Bar -->
    <div class="w-full px-4 animate-fade-in-up" style="animation-delay: 0.1s;">
      <SearchBar autoFocus={true} />
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-wrap justify-center gap-4 mt-10 animate-fade-in-up" style="animation-delay: 0.2s;">
      <button class="bg-[var(--button-bg)] hover:bg-[var(--button-hover)] border border-transparent shadow-sm hover:shadow-md text-[var(--button-text)] px-6 py-2.5 rounded-full font-medium text-sm transition-all duration-300 cursor-pointer transform hover:-translate-y-0.5" onclick="document.querySelector('form').submit()">
        {t.searchButton}
      </button>
      <button class="bg-[var(--button-bg)] hover:bg-[var(--button-hover)] border border-transparent shadow-sm hover:shadow-md text-[var(--button-text)] px-6 py-2.5 rounded-full font-medium text-sm transition-all duration-300 cursor-pointer transform hover:-translate-y-0.5" onclick="document.querySelector('form').submit()">
        {t.feelingLucky}
      </button>
    </div>

    <!-- Language Info -->
    <div class="mt-12 text-sm text-[var(--text-muted)] animate-fade-in-up" style="animation-delay: 0.3s;">
      Ofrecido por Search en: 
      <span class="font-medium">
        <LanguageToggle />
      </span>
    </div>

    <!-- Manual URL Submission -->
    <div class="mt-10 w-full max-w-[650px] animate-fade-in-up" style="animation-delay: 0.4s;">
      <div class="crawl-box p-6 rounded-2xl border border-[var(--search-border)] backdrop-blur-sm">
        <h2 class="text-base font-semibold text-[var(--text-color)] mb-2 flex items-center gap-2">
          <svg class="w-5 h-5 text-[var(--link-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          Añadir URL al índice
        </h2>
        <p class="text-sm text-[var(--text-muted)] mb-4">Introduce una URL para que el crawler la indexe y aparezca en futuras búsquedas.</p>
        <div class="flex gap-3">
          <input 
            type="url" 
            id="crawl-url"
            placeholder="https://ejemplo.com"
            class="flex-1 bg-[var(--button-bg)] border border-[var(--button-border)] rounded-xl px-4 py-2.5 text-sm text-[var(--text-color)] outline-none focus:border-[var(--link-color)] transition-colors"
          />
          <button id="crawl-btn" class="bg-[var(--button-bg)] hover:bg-[var(--button-hover)] border border-[var(--button-border)] text-[var(--button-text)] px-5 py-2.5 rounded-xl font-medium text-sm transition-all duration-300 cursor-pointer flex items-center gap-2 whitespace-nowrap">
            <span id="crawl-btn-text">Encolar</span>
            <svg id="crawl-btn-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </div>
        <p id="crawl-status" class="mt-3 text-sm font-medium hidden"></p>
      </div>
    </div>

  </main>

  <footer class="bg-[var(--footer-bg)] text-[var(--footer-text)] backdrop-blur-md border-t border-[var(--button-border)] flex flex-col transition-colors duration-300">
    <div class="flex flex-col sm:flex-row justify-between items-center px-8 py-4 text-sm font-medium flex-wrap gap-4">
      <div class="flex space-x-6">
        <a href="#" class="hover:text-[var(--link-color)] transition-colors">{t.about}</a>
        <a href="#" class="hover:text-[var(--link-color)] transition-colors">{t.privacy}</a>
        <a href="#" class="hover:text-[var(--link-color)] transition-colors">{t.terms}</a>
      </div>
      <div class="flex space-x-6 items-center">
        <div class="hover:text-[var(--link-color)] transition-colors">
          <ThemeToggle />
        </div>
        <a href="#" class="hover:text-[var(--link-color)] transition-colors">{t.settings}</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .crawl-box {
    background: var(--card-bg);
    box-shadow: var(--search-shadow);
  }
</style>

<script is:inline>
(function() {
  const input = document.getElementById('crawl-url');
  const btn = document.getElementById('crawl-btn');
  const status = document.getElementById('crawl-status');
  const btnText = document.getElementById('crawl-btn-text');
  const btnIcon = document.getElementById('crawl-btn-icon');
  if (!input || !btn || !status) return;

  function setStatus(msg, type) {
    status.textContent = msg;
    status.classList.remove('hidden', 'text-emerald-500', 'text-red-500', 'text-[var(--text-muted)]');
    if (type === 'success') status.classList.add('text-emerald-500');
    else if (type === 'error') status.classList.add('text-red-500');
    else status.classList.add('text-[var(--text-muted)]');
  }

  async function submitUrl() {
    const url = input.value.trim();
    if (!url) {
      setStatus('Por favor introduce una URL válida.', 'error');
      return;
    }
    if (!url.startsWith('http://') && !url.startsWith('https://')) {
      setStatus('La URL debe comenzar con http:// o https://', 'error');
      return;
    }

    btn.disabled = true;
    btn.classList.add('opacity-60', 'cursor-not-allowed');
    setStatus('Enviando...', 'info');

    try {
      const res = await fetch('/api/crawl', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ urls: [url], force: true }),
      });
      const data = await res.json();

      if (res.ok && data.success) {
        const msg = data.skipped > 0
          ? `URL encolada: ${data.queued} nueva(s), ${data.skipped} ya indexada(s) recientemente.`
          : 'URL encolada correctamente para indexación.';
        setStatus(msg, 'success');
        input.value = '';
      } else {
        setStatus(data.error || 'Error al encolar la URL.', 'error');
      }
    } catch (e) {
      setStatus('No se pudo conectar con el crawler. ¿Está corriendo?', 'error');
    } finally {
      btn.disabled = false;
      btn.classList.remove('opacity-60', 'cursor-not-allowed');
    }
  }

  btn.addEventListener('click', submitUrl);
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') submitUrl();
  });
})();
</script>
