---
import Layout from '../layouts/Layout.astro';
import CrawlBox from '../components/CrawlBox.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const langCookie = Astro.cookies.get('lang')?.value || 'es';

// Handle authentication
const expectedToken = process.env.ADMIN_TOKEN || 'admin123@';
let isAuthenticated = false;

if (Astro.url.searchParams.get('logout') === 'true') {
  Astro.cookies.delete('admin_token', { path: '/' });
  isAuthenticated = false;
} else if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const token = data.get('token');
  if (token === expectedToken) {
    Astro.cookies.set('admin_token', expectedToken, { path: '/' });
    isAuthenticated = true;
  }
} else {
  const cookieToken = Astro.cookies.get('admin_token')?.value;
  isAuthenticated = cookieToken === expectedToken;
}

// Fetch stats if authenticated
let stats: any = null;
let queue: any = null;
let status: any = null;

if (isAuthenticated) {
  // Use import.meta.env first (Astro .env support), fallback to process.env, then default to 8081
  const CRAWLER_API = import.meta.env.CRAWLER_API || process.env.CRAWLER_API || 'http://localhost:8081/api/v1';
  try {
    const [statsRes, queueRes, statusRes] = await Promise.all([
      fetch(`${CRAWLER_API}/stats`),
      fetch(`${CRAWLER_API}/queue`),
      fetch(`${CRAWLER_API}/crawler/status`)
    ]);
    
    if (statsRes.ok) stats = (await statsRes.json()).data;
    if (queueRes.ok) queue = await queueRes.json();
    if (statusRes.ok) status = await statusRes.json();
  } catch (e) {
    console.error('Failed to fetch admin data', e);
  }
}
---

<Layout title="Admin Dashboard | Suvy" description="Administration panel for Suvy search engine.">
  <div class="min-h-[calc(100vh-80px)] text-[var(--text-color)] p-6 transition-colors duration-300">
    <div class="max-w-6xl mx-auto space-y-8 animate-fade-in-up">
      
      <!-- Header -->
      <header class="flex justify-between items-center bg-[var(--card-bg)] p-6 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)]">
        <div class="flex items-center gap-4">
          <a href="/" class="hover:opacity-80 transition-opacity">
            <img src="/logo.webp" alt="Suvy" class="h-10 w-auto" width="40" height="40" />
          </a>
          <h1 class="text-2xl font-bold tracking-tight">Admin Dashboard</h1>
        </div>
        
        <div class="flex items-center gap-4">
          <ThemeToggle />
          {isAuthenticated && (
            <a href="?logout=true" class="bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white px-4 py-2 rounded-xl text-sm font-medium transition-colors">
              Logout
            </a>
          )}
        </div>
      </header>

      {!isAuthenticated ? (
        <!-- Login Form -->
        <main class="flex flex-col items-center justify-center mt-20">
          <form method="POST" class="bg-[var(--card-bg)] p-8 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)] w-full max-w-md space-y-6">
            <h2 class="text-xl font-semibold text-center">Authentication Required</h2>
            <p class="text-sm text-[var(--text-muted)] text-center">Please enter the admin token to access the dashboard.</p>
            
            <div>
              <input 
                type="password" 
                name="token" 
                placeholder="Admin Token" 
                required
                class="w-full bg-[var(--button-bg)] border border-[var(--button-border)] rounded-xl px-4 py-3 text-sm focus:border-[var(--link-color)] outline-none transition-colors"
              />
            </div>
            
            <button type="submit" class="w-full bg-[var(--link-color)] hover:bg-blue-600 text-white font-medium py-3 rounded-xl transition-colors">
              Login
            </button>
          </form>
        </main>
      ) : (
        <!-- Dashboard content -->
        <main class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          
          <!-- Crawler Status / Controls -->
          <section class="lg:col-span-1 space-y-8">
            <div class="bg-[var(--card-bg)] p-6 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)]">
              <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <span class={`w-3 h-3 rounded-full ${status?.status === 'running' ? 'bg-emerald-500 animate-pulse' : 'bg-red-500'}`}></span>
                Crawler Status
              </h2>
              <div class="space-y-4">
                <div class="flex justify-between items-center py-2 border-b border-[var(--button-border)]">
                  <span class="text-[var(--text-muted)]">State</span>
                  <span class="font-medium capitalize">{status?.status || 'Unknown'}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-[var(--button-border)]">
                  <span class="text-[var(--text-muted)]">Pages Crawled (Session)</span>
                  <span class="font-medium">{status?.pages_crawled?.toLocaleString() || 0}</span>
                </div>
                <div class="flex justify-between items-center py-2">
                  <span class="text-[var(--text-muted)]">Errors (Session)</span>
                  <span class="font-medium text-red-500">{status?.pages_errored?.toLocaleString() || 0}</span>
                </div>
              </div>
            </div>

            <!-- Removed redundant Manual URL Crawl wrapper -->
            <CrawlBox lang={langCookie} />
          </section>

          <!-- Storage and Queue Stats -->
          <section class="lg:col-span-2 space-y-8">
            
            <!-- Index Stats -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              <div class="bg-[var(--card-bg)] p-5 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)]">
                <p class="text-sm text-[var(--text-muted)] mb-1">Total Indexed</p>
                <p class="text-2xl font-bold">{stats?.stats?.total_pages?.toLocaleString() || 0}</p>
              </div>
              <div class="bg-[var(--card-bg)] p-5 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)]">
                <p class="text-sm text-[var(--text-muted)] mb-1">Known Domains</p>
                <p class="text-2xl font-bold">{stats?.stats?.total_domains?.toLocaleString() || 0}</p>
              </div>
              <div class="bg-[var(--card-bg)] p-5 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)]">
                <p class="text-sm text-[var(--text-muted)] mb-1">Index Size</p>
                <p class="text-2xl font-bold">
                  {stats?.stats?.db_size_bytes ? (stats.stats.db_size_bytes / 1024 / 1024).toFixed(1) + ' MB' : '0 MB'}
                </p>
              </div>
              <div class="bg-[var(--card-bg)] p-5 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)]">
                <p class="text-sm text-[var(--text-muted)] mb-1">Known Images</p>
                <p class="text-2xl font-bold">{stats?.stats?.total_images?.toLocaleString() || 0}</p>
              </div>
            </div>

            <!-- Queue Stats -->
            <div class="bg-[var(--card-bg)] p-6 rounded-2xl shadow-[var(--search-shadow)] border border-[var(--search-border)]">
              <h2 class="text-lg font-semibold mb-4">Frontier Queue</h2>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                <div>
                  <p class="text-sm text-[var(--text-muted)] mb-1">Pending URLs</p>
                  <p class="text-xl font-medium">{queue?.pending?.toLocaleString() || 0}</p>
                </div>
                <div>
                  <p class="text-sm text-[var(--text-muted)] mb-1">Total Enqueued</p>
                  <p class="text-xl font-medium">{queue?.total_enqueued?.toLocaleString() || 0}</p>
                </div>
                <div>
                  <p class="text-sm text-[var(--text-muted)] mb-1">Total Dequeued</p>
                  <p class="text-xl font-medium">{queue?.total_dequeued?.toLocaleString() || 0}</p>
                </div>
              </div>
            </div>
            
          </section>

        </main>
      )}

    </div>
  </div>
</Layout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
