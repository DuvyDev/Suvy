---
export interface Props {
  query: string;
  lang: string;
}

const { query, lang } = Astro.props;
const maptilerApiKey = process.env.MAP_TILER_API_KEY || '';
---

<div class="map-card" id="map-card" style="display: none;" data-query={query} data-lang={lang} data-apikey={maptilerApiKey}>
  <div class="map-header">
    <svg class="map-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    <div class="map-title-wrap">
      <h3 class="map-title" id="map-title"></h3>
      <span class="map-type" id="map-type"></span>
    </div>
  </div>

  <div class="map-preview-container" id="map-container" style="display: none;"></div>
  
  <div class="map-coords" id="map-coords-container">
    <span id="map-lat"></span>
    <span class="map-coords-sep">·</span>
    <span id="map-lon"></span>
  </div>

  <a id="map-link" href="#" class="map-link">
    Ver en OpenStreetMap
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>

  <span class="map-attribution">&copy; OpenStreetMap contributors &copy; MapTiler</span>
</div>

<script>
function initMapCard() {
  const mapCard = document.getElementById('map-card');
  if (!mapCard || mapCard.dataset.loaded) return;
  mapCard.dataset.loaded = 'true';

  const query = mapCard.getAttribute('data-query');
  const lang = mapCard.getAttribute('data-lang');
  const apiKey = mapCard.getAttribute('data-apikey');

  if (query) {
    fetch(`/api/map?q=${encodeURIComponent(query)}&lang=${encodeURIComponent(lang || 'es')}`)
      .then(r => r.json())
      .then(data => {
        if (data.found && data.result) {
          const { lat, lon, name, type, osmLink } = data.result;

          const titleEl = document.getElementById('map-title');
          if (titleEl) titleEl.textContent = name;

          const typeEl = document.getElementById('map-type');
          if (typeEl) typeEl.textContent = type;

          const latDir = lat >= 0 ? 'N' : 'S';
          const lonDir = lon >= 0 ? 'E' : 'W';
          const latFormatted = `${Math.abs(lat).toFixed(4)}° ${latDir}`;
          const lonFormatted = `${Math.abs(lon).toFixed(4)}° ${lonDir}`;

          const latEl = document.getElementById('map-lat');
          if (latEl) latEl.textContent = latFormatted;

          const lonEl = document.getElementById('map-lon');
          if (lonEl) lonEl.textContent = lonFormatted;

          const linkEl = document.getElementById('map-link');
          if (linkEl && linkEl instanceof HTMLAnchorElement) linkEl.href = osmLink;

          mapCard.style.display = 'block';
          mapCard.classList.add('animate-fade-in-up');

          const container = document.getElementById('map-container');
          if (container && apiKey) {
            container.style.display = 'block';
            if (!document.querySelector('link[href*="leaflet"]')) {
              const cssLink = document.createElement('link');
              cssLink.rel = 'stylesheet';
              cssLink.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
              cssLink.crossOrigin = '';
              document.head.appendChild(cssLink);
            }

            const initMap = () => {
              try {
                const mapId = 'leaflet-map-' + Date.now();
                container.id = mapId;
                const map = window.L.map(mapId, { center: [lat, lon], zoom: 13, zoomControl: false });
                window.L.tileLayer(
                  'https://api.maptiler.com/maps/streets-v4/{z}/{x}/{y}.png?key=' + apiKey,
                  { tileSize: 512, zoomOffset: -1, attribution: '&copy; OpenStreetMap &copy; MapTiler' }
                ).addTo(map);
                window.L.marker([lat, lon]).addTo(map).bindPopup(name).openPopup();
                setTimeout(() => map.invalidateSize(), 50);
              } catch(e) {
                container.innerHTML = '<div class="map-error"><span class="map-error-text">Map unavailable</span></div>';
              }
            };

            if (window.L) {
              initMap();
            } else {
              const script = document.createElement('script');
              script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
              script.crossOrigin = '';
              script.onload = initMap;
              document.head.appendChild(script);
            }
          } else if (container) {
            container.style.display = 'block';
            container.innerHTML = `<a href="${osmLink}" class="map-preview-link" style="display:flex; flex-direction:column; align-items:center; justify-content:center; padding: 2rem; color: var(--link-color); text-decoration:none;"><svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="margin-bottom:0.5rem;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg><span>Open Map</span></a>`;
          }
        }
      })
      .catch(e => console.error('Error fetching map:', e));
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initMapCard);
} else {
  initMapCard();
}
document.addEventListener('astro:page-load', initMapCard);
</script>

<style>
  .map-card {
    background: var(--card-bg);
    border: 1px solid var(--search-border);
    border-radius: 1.25rem;
    padding: 1.25rem;
    backdrop-filter: blur(12px);
    box-shadow: var(--search-shadow);
    transition: all 0.3s ease;
  }
  .map-card:hover {
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
    border-color: var(--link-color);
  }
  .map-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .map-icon {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--link-color);
    flex-shrink: 0;
  }
  .map-title-wrap {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .map-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-color);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .map-type {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: capitalize;
  }
  .map-preview-container {
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 0.75rem;
    background: var(--button-bg);
    position: relative;
  }
  .map-preview-container.leaflet-container {
    width: 100%;
    height: 200px;
    border-radius: 0.75rem;
    z-index: 1;
  }
  .map-preview-container.leaflet-container a {
    outline: none;
  }
  .map-preview-container.leaflet-container .leaflet-control-attribution {
    background: rgba(255,255,255,0.8);
    font-size: 10px;
    padding: 2px 4px;
  }
  .map-preview-container.leaflet-container .leaflet-popup-content-wrapper {
    border-radius: 4px;
    padding: 4px 8px;
  }
  .map-error {
    width: 100%;
    height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: var(--button-bg);
  }
  .map-error-text {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .map-coords {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: monospace;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .map-coords-sep {
    opacity: 0.4;
  }
  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--link-color);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .map-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
  .map-attribution {
    display: block;
    font-size: 0.65rem;
    color: var(--text-muted);
    opacity: 0.6;
    margin-top: 0.6rem;
  }
</style>