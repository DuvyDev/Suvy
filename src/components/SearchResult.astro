---
import type { SearchResult } from '../lib/search';
import type { SearchResultItem } from '../lib/duckduckgo';
import Favicon from './Favicon.astro';
import Sitelinks from './Sitelinks.astro';

export interface Props {
  result: SearchResult;
  sitelinks?: SearchResultItem[];
  isFirst?: boolean;
}

const { result, sitelinks = [], isFirst = false } = Astro.props;

const domain = (() => {
  try {
    return new URL(result.url).hostname.replace(/^www\./, '');
  } catch {
    return '';
  }
})();

// Helper to format URL for display
const displayUrl = (() => {
  try {
    const urlObj = new URL(result.url);
    return `${urlObj.protocol}//${urlObj.hostname}${urlObj.pathname !== '/' ? urlObj.pathname : ''}`;
  } catch(e) {
    return result.url;
  }
})();

// Extract a human-friendly site name from domain + title
function getSiteName(domain: string, title: string): string {
  const known: Record<string, string> = {
    'wikipedia.org': 'Wikipedia',
    'es.wikipedia.org': 'Wikipedia',
    'en.wikipedia.org': 'Wikipedia',
    'github.com': 'GitHub',
    'stackoverflow.com': 'Stack Overflow',
    'youtube.com': 'YouTube',
    'reddit.com': 'Reddit',
    'infobae.com': 'Infobae',
    'elobservador.com.uy': 'El Observador',
    'telenoche.com.uy': 'Telenoche',
    'xataka.com': 'Xataka',
  };

  // Direct match on full domain
  if (known[domain]) return known[domain];

  // Try to extract from title using common separators.
  // Prefer the shortest part — usually the site name, not the slogan.
  const separators = [' | ', ' - ', ' — ', ' · ', ' › ', ' : ', ' « ', ' » '];
  for (const sep of separators) {
    const parts = title.split(sep);
    if (parts.length > 1) {
      const candidates = parts
        .map((p) => p.trim())
        .filter((p) => p.length > 1 && p.length < 60);
      if (candidates.length > 0) {
        // Pick the shortest candidate (site names are short, slogans are long)
        const shortest = candidates.reduce((a, b) =>
          a.length < b.length ? a : b
        );
        return shortest;
      }
    }
  }

  // Fallback: clean domain name — strip common TLDs then split on dots
  const clean = domain
    .replace(/^www\./, '')
    // Remove common two-level TLDs first (e.g. .com.uy, .co.uk)
    .replace(/\.com\.[a-z]{2}$/i, '')
    .replace(/\.co\.[a-z]{2}$/i, '')
    .replace(/\.org\.[a-z]{2}$/i, '')
    .replace(/\.net\.[a-z]{2}$/i, '')
    // Remove common single TLDs
    .replace(/\.(com|org|net|edu|gov|io|es|fr|de|it|pt|ar|mx|us|uk|info|app|dev|tech|blog|news)$/i, '')
    .replace(/\./g, ' ');

  // Split into words and capitalise each
  return clean
    .split(' ')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

const siteName = getSiteName(domain, result.title);

let displaySiteName = siteName;
let displayTitle = result.title;

// Special formatting for Reddit
if (domain === 'reddit.com' || domain.endsWith('.reddit.com')) {
  try {
    const urlObj = new URL(result.url);
    const pathParts = urlObj.pathname.split('/');
    if (pathParts[1] === 'r' && pathParts[2]) {
      displaySiteName = `Reddit · r/${pathParts[2]}`;
    }
  } catch (e) {}

  // Clean the title by removing " : r/subreddit" or " - Reddit" suffixes
  displayTitle = result.title
    .replace(/\s*[:-]\s*r\/[a-zA-Z0-9_]+\s*$/i, '')
    .replace(/\s*-\s*Reddit\s*$/i, '');
}

// Relative time helper
function relativeTime(isoDate: string | undefined): string | null {
  if (!isoDate) return null;
  const date = new Date(isoDate);
  if (isNaN(date.getTime())) return null;

  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffSec = Math.floor(diffMs / 1000);
  const diffMin = Math.floor(diffSec / 60);
  const diffHour = Math.floor(diffMin / 60);
  const diffDay = Math.floor(diffHour / 24);

  if (diffSec < 60) return 'Hace un momento';
  if (diffMin === 1) return 'Hace 1 minuto';
  if (diffMin < 60) return `Hace ${diffMin} minutos`;
  if (diffHour === 1) return 'Hace 1 hora';
  if (diffHour < 24) return `Hace ${diffHour} horas`;
  if (diffDay === 1) return 'Hace 1 día';
  if (diffDay <= 7) return `Hace ${diffDay} días`;

  // Over 7 days — show absolute date DD-MM-YYYY
  const d = String(date.getDate()).padStart(2, '0');
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const y = date.getFullYear();
  return `${d}-${m}-${y}`;
}

const timeAgo = relativeTime(result.meta?.publishedAt);
const crawlerApi = process.env.CRAWLER_API || 'http://localhost:8080/api/v1';
---

<div class="mb-6 max-w-[700px] w-full" data-api-url={crawlerApi}>
  <div class="search-result-card group flex flex-col p-4 rounded-2xl bg-[var(--card-bg)] backdrop-blur-sm border border-transparent hover:border-[var(--search-border)] hover:bg-[var(--card-hover)] hover:-translate-y-1 hover:shadow-lg transition-all duration-300 cursor-pointer" onclick={`window.open('${result.url}', '_self')`} data-url={result.url}>
    <a href={result.url} class="search-result-link block mb-2" onclick="event.stopPropagation();">
      <span class="site-name">{displaySiteName}</span>
      <div class="flex items-center space-x-3 mb-2 mt-1">
        <div class="w-7 h-7 rounded-full bg-[var(--button-bg)] flex items-center justify-center shadow-sm">
          <Favicon domain={domain} size={32} class="w-4 h-4 rounded-sm" />
        </div>
        <div class="flex flex-col">
          <span class="text-xs text-[var(--text-muted)] truncate max-w-[250px] sm:max-w-[400px] font-medium">{displayUrl}</span>
        </div>
      </div>
      <h3 class="text-[22px] text-[var(--link-color)] group-hover:underline visited:text-[var(--link-visited)] font-semibold leading-tight line-clamp-2">
        {displayTitle}
      </h3>
    </a>
    {timeAgo && (
      <span class="text-[12px] text-[var(--text-muted)] font-medium mb-1">{timeAgo}</span>
    )}
    <p class="result-content text-[15px] text-[var(--text-color)] leading-relaxed line-clamp-3 opacity-90 font-light" set:html={result.content}></p>
    {sitelinks.length > 0 ? (
      <Sitelinks links={sitelinks} />
    ) : isFirst ? (
      <div class="async-sitelinks" data-domain={domain} data-exclude={result.url}></div>
    ) : null}
  </div>
</div>

<style>
  .site-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-color);
    line-height: 1.2;
  }
</style>

<style is:global>
  /* Force search highlight to be bold only — no yellow background */
  .result-content b,
  .result-content strong,
  .result-content mark,
  .result-content span[style*="background"],
  .result-content span[style*="BACKGROUND"] {
    background: transparent !important;
    color: inherit !important;
    font-weight: 600 !important;
  }

  /* Sitelinks — must be global because elements are created dynamically by JS */
  .sitelinks {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4rem 1rem;
    margin-top: 0.6rem;
    padding-left: 0.25rem;
  }
  @media (max-width: 640px) {
    .sitelinks {
      grid-template-columns: 1fr;
    }
  }
  .sitelink {
    display: flex;
    flex-direction: column;
    padding: 0.35rem 0.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s;
    min-width: 0;
  }
  .sitelink:hover {
    background: var(--button-border);
  }
  .sitelink-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--link-color);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sitelink:hover .sitelink-title {
    text-decoration: underline;
  }
  .sitelink-url {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script>
function initSearchResult() {
  const container = document.querySelector('.async-sitelinks');
  if (container && container.dataset.loaded) return;
  if (container) container.dataset.loaded = 'true';

  if (container) {
    const query = new URLSearchParams(window.location.search).get('q');
    const domain = container.getAttribute('data-domain');
    const exclude = container.getAttribute('data-exclude');
    if (query && domain) {
      fetch(`/api/sitelinks?q=${encodeURIComponent(query)}&domain=${encodeURIComponent(domain)}&exclude=${encodeURIComponent(exclude || '')}`)
        .then(r => r.json())
        .then(data => {
          if (!data.sitelinks || data.sitelinks.length === 0) return;
          const grid = document.createElement('div');
          grid.className = 'sitelinks';
          data.sitelinks.forEach(link => {
            let displayPath;
            try {
              const u = new URL(link.url);
              displayPath = u.pathname !== '/' ? u.pathname : u.hostname;
            } catch { displayPath = link.url; }
            const a = document.createElement('a');
            a.href = link.url;
            a.className = 'sitelink search-result-link';
            a.title = link.content || '';
            a.onclick = (e) => e.stopPropagation();
            a.innerHTML = `<span class="sitelink-title">${link.title}</span><span class="sitelink-url">${displayPath}</span>`;
            grid.appendChild(a);
          });
          container.replaceWith(grid);
        })
        .catch(() => {});
    }
  }

  function trackClick(url) {
    const query = new URLSearchParams(window.location.search).get('q');
    const apiUrl = document.querySelector('[data-api-url]')?.getAttribute('data-api-url') || 'http://localhost:8080/api/v1';

    if (url && query) {
      fetch(`${apiUrl}/interact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query, url }),
        keepalive: true
      }).catch(console.error);
    }
  }

  document.querySelectorAll('.search-result-card').forEach(card => {
    card.addEventListener('click', () => {
      trackClick(card.getAttribute('data-url'));
    });
  });

  document.querySelectorAll('.search-result-link').forEach(link => {
    link.addEventListener('click', (e) => {
      trackClick(link.getAttribute('href'));
    });
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initSearchResult);
} else {
  initSearchResult();
}
document.addEventListener('astro:page-load', initSearchResult);
</script>
