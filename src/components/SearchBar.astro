---
import { getTranslation } from '../i18n/translations';

export interface Props {
  initialValue?: string;
  autoFocus?: boolean;
}

const { initialValue = '', autoFocus = false } = Astro.props;
const langCookie = Astro.cookies.get('lang')?.value;
const t = getTranslation(langCookie);
---

<form action="/search" method="get" class="w-full max-w-[650px] mx-auto group">
  <div class="relative flex items-center w-full h-14 rounded-full border border-[var(--search-border)] bg-[var(--search-bg)] backdrop-blur-md shadow-[var(--search-shadow)] hover:shadow-lg focus-within:shadow-xl focus-within:ring-2 focus-within:ring-[var(--search-ring)] transition-all duration-300 px-5 mt-6">
    <svg focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 text-[var(--text-muted)] mr-3 group-focus-within:text-[var(--link-color)] transition-colors duration-300">
      <path fill="currentColor" d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
    </svg>
    <input 
      type="text" 
      name="q" 
      value={initialValue}
      placeholder={t.searchPlaceholder}
      class="flex-1 bg-transparent outline-none text-[17px] text-[var(--text-color)] placeholder:text-[var(--text-muted)] w-full"
      autocomplete="off"
      autofocus={autoFocus}
    />
    <button type="submit" aria-label="Search" class="p-2 rounded-full hover:bg-[var(--button-border)] transition-colors">
      <svg class="w-6 h-6 text-[var(--link-color)]" focusable="false" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
         <path fill="currentColor" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
      </svg>
    </button>
  </div>
</form>
