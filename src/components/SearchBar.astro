---
import { getTranslation } from '../i18n/translations';

export interface Props {
  initialValue?: string;
  query?: string;
  autoFocus?: boolean;
  action?: string;
  compact?: boolean;
}

const { initialValue = '', query, autoFocus = false, action = '/search', compact = false } = Astro.props;
const value = query ?? initialValue;
const langCookie = Astro.cookies.get('lang')?.value;
const t = getTranslation(langCookie);
---

<search-bar data-action={action} data-compact={compact ? 'true' : 'false'} data-autofocus={autoFocus ? 'true' : 'false'}>
  <form action={action} method="get" class="w-full max-w-[650px] mx-auto group" id="search-form">
    <div class:list={['search-container', { compact }]}>
      <svg focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="search-icon">
        <path fill="currentColor" d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
      </svg>
      <input 
        type="text" 
        name="q" 
        id="search-input"
        value={value}
        placeholder={t.searchPlaceholder}
        class="search-input"
        autocomplete="off"
        autofocus={autoFocus}
      />
      <button type="button" aria-label="Clear" id="search-clear" class="search-clear" style={value ? '' : 'display:none;'}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      <button type="submit" aria-label="Search" class="search-btn">
        <svg class="w-6 h-6 text-[var(--link-color)]" focusable="false" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
           <path fill="currentColor" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
        </svg>
      </button>

      <!-- Autocomplete dropdown -->
      <div id="suggest-dropdown" class="suggest-dropdown" style="display: none;">
        <!-- Items injected by JS -->
      </div>
    </div>
  </form>
</search-bar>

<style>
  search-bar {
    display: block;
    width: 100%;
  }
  .search-container {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    height: 3.5rem;
    border-radius: 9999px;
    border: 1px solid var(--search-border);
    background: var(--search-bg);
    backdrop-filter: blur(12px);
    padding: 0 1.25rem;
    margin-top: 1.5rem;
    transition: all 0.3s ease;
  }
  .search-container.compact {
    margin-top: 0;
  }

  .search-container:hover {
    border-color: var(--search-border-hover, var(--search-ring));
  }

  .search-container:focus-within {
    border-color: var(--search-ring);
    background: var(--bg-color);
  }

  .search-container.has-suggestions {
    border-radius: 1.5rem 1.5rem 0 0;
  }

  .search-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--text-muted);
    margin-right: 0.75rem;
    flex-shrink: 0;
    transition: color 0.3s;
  }

  .search-container:focus-within .search-icon {
    color: var(--link-color);
  }

  .search-input {
    flex: 1;
    background: transparent;
    outline: none;
    font-size: 1.06rem;
    color: var(--text-color);
    width: 100%;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-btn {
    padding: 0.5rem;
    border-radius: 9999px;
    transition: background 0.2s;
    cursor: pointer;
    background: none;
    border: none;
  }

  .search-btn:hover {
    background: var(--button-border);
  }

  .search-clear {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    border-radius: 50%;
    cursor: pointer;
    background: none;
    border: none;
    color: var(--text-muted);
    transition: all 0.2s;
    margin-right: 0.25rem;
  }
  .search-clear:hover {
    color: var(--text-color);
    background: var(--button-border);
  }

</style>

<style is:global>
  /* Autocomplete dropdown — must be global because items are injected by client JS */
  .suggest-dropdown {
    position: absolute;
    top: 100%;
    left: -1px;
    right: -1px;
    background: var(--search-bg, var(--bg-color));
    border: 1px solid var(--search-border);
    border-top: 1px solid var(--button-border, rgba(128,128,128,0.2));
    border-radius: 0 0 1.25rem 1.25rem;
    overflow: hidden;
    z-index: 200;
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }

  .suggest-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1.25rem;
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .suggest-item:hover,
  .suggest-item.active {
    background: var(--button-border, rgba(99, 102, 241, 0.1));
  }

  .suggest-item:last-child {
    border-radius: 0 0 1.25rem 1.25rem;
  }

  .suggest-icon {
    width: 1rem;
    height: 1rem;
    color: var(--text-muted);
    flex-shrink: 0;
    opacity: 0.6;
  }

  .suggest-text {
    font-size: 0.92rem;
    color: var(--text-color);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .suggest-text mark {
    background: none;
    color: var(--link-color);
    font-weight: 600;
  }
</style>

<script>
  class SearchBar extends HTMLElement {
    private input: HTMLInputElement | null = null;
    private dropdown: HTMLElement | null = null;
    private form: HTMLFormElement | null = null;
    private container: HTMLElement | null = null;
    private debounceTimer: any = null;
    private activeIndex: number = -1;
    private suggestions: string[] = [];
    private currentQuery: string = '';

    constructor() {
      super();
    }

    connectedCallback() {
      this.input = this.querySelector('#search-input');
      this.dropdown = this.querySelector('#suggest-dropdown');
      this.form = this.querySelector('#search-form');
      this.container = this.querySelector('.search-container');
      const clearBtn = this.querySelector('#search-clear') as HTMLElement | null;

      if (!this.input || !this.dropdown || !this.form || !this.container) return;

      // Clear button
      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          this.input!.value = '';
          clearBtn.style.display = 'none';
          this.input!.focus();
          this.hideDropdown();
        });
      }

      this.input.addEventListener('input', () => {
        clearTimeout(this.debounceTimer);
        const q = this.input!.value.trim();
        if (clearBtn) {
          clearBtn.style.display = q.length > 0 ? '' : 'none';
        }
        if (q.length < 1) {
          this.hideDropdown();
          return;
        }
        this.debounceTimer = setTimeout(() => {
          this.fetchSuggestions(q);
        }, 250);
      });

      this.input.addEventListener('keydown', (e) => {
        if (this.suggestions.length === 0) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          this.activeIndex = (this.activeIndex + 1) % this.suggestions.length;
          this.renderDropdown();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          this.activeIndex = this.activeIndex <= 0 ? this.suggestions.length - 1 : this.activeIndex - 1;
          this.renderDropdown();
        } else if (e.key === 'Enter' && this.activeIndex >= 0) {
          e.preventDefault();
          this.input!.value = this.suggestions[this.activeIndex];
          this.hideDropdown();
          this.form!.submit();
        } else if (e.key === 'Escape') {
          this.hideDropdown();
        }
      });

      this.input.addEventListener('blur', () => {
        setTimeout(() => this.hideDropdown(), 200);
      });

      this.input.addEventListener('focus', () => {
        if (this.input!.value.trim().length >= 1 && this.suggestions.length > 0) {
          this.renderDropdown();
        }
      });
    }

    private highlightMatch(text: string, query: string) {
      if (!query) return text;
      const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return text.replace(new RegExp('(' + escaped + ')', 'gi'), '<mark>$1</mark>');
    }

    private renderDropdown() {
      if (!this.dropdown || !this.container) return;

      if (this.suggestions.length === 0) {
        this.dropdown.style.display = 'none';
        this.container.classList.remove('has-suggestions');
        return;
      }

      this.dropdown.innerHTML = this.suggestions.map((s, i) => {
        return `<div class="suggest-item${i === this.activeIndex ? ' active' : ''}" data-index="${i}">
          <svg class="suggest-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path></svg>
          <span class="suggest-text">${this.highlightMatch(s, this.currentQuery)}</span>
          </div>`;
      }).join('');

      this.dropdown.style.display = 'block';
      this.container.classList.add('has-suggestions');

      this.dropdown.querySelectorAll('.suggest-item').forEach((item) => {
        item.addEventListener('mousedown', (e) => {
          e.preventDefault();
          const idx = parseInt(item.getAttribute('data-index') || '0');
          this.input!.value = this.suggestions[idx];
          this.hideDropdown();
          this.form!.submit();
        });
      });
    }

    private hideDropdown() {
      if (this.dropdown && this.container) {
        this.dropdown.style.display = 'none';
        this.container.classList.remove('has-suggestions');
      }
      this.suggestions = [];
      this.activeIndex = -1;
    }

    private async fetchSuggestions(query: string) {
      if (query.length < 1) {
        this.hideDropdown();
        return;
      }

      try {
        const res = await fetch('/api/suggest?q=' + encodeURIComponent(query));
        if (!res.ok) return;
        const data = await res.json();
        if (Array.isArray(data) && data.length >= 2) {
          this.currentQuery = query;
          this.suggestions = data[1] || [];
          this.activeIndex = -1;
          this.renderDropdown();
        }
      } catch (e) {
        // Silently ignore
      }
    }
  }

  customElements.define('search-bar', SearchBar);
</script>
