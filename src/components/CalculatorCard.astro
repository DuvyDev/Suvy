---
import { getCalculator } from '../lib/calculator';
import { getTranslation } from '../i18n/translations';

interface Props {
  q: string;
  lang: string;
}

const { q, lang } = Astro.props;
const t = getTranslation(lang);

const data = getCalculator(q);
if (!data) return;
---

<calculator-card class="calculator-card animate-fade-in-up">
  <div class="calc-header">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--link-color)]">
        <rect x="4" y="2" width="16" height="20" rx="2"/>
        <line x1="8" y1="6" x2="16" y2="6"/>
        <line x1="8" y1="10" x2="8" y2="10"/>
        <line x1="12" y1="10" x2="12" y2="10"/>
        <line x1="16" y1="10" x2="16" y2="10"/>
        <line x1="8" y1="14" x2="8" y2="14"/>
        <line x1="12" y1="14" x2="12" y2="14"/>
        <line x1="16" y1="14" x2="16" y2="14"/>
        <line x1="8" y1="18" x2="16" y2="18"/>
      </svg>
      <span class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wide">{t.calculator_title}</span>
    </div>
  </div>

  <div class="calc-display-row">
    <div class="calc-expression" id="calc-expr-main"></div>
    <div class="calc-display" id="calc-display-main">
      {data.mode === 'expression' ? (data.error ? data.error : data.result) : '0'}
    </div>
  </div>

  <div class="calc-main-grid">
    <button class="calc-btn calc-btn-sci active-deg" data-action="deg" id="calc-deg-btn">DEG</button>
    <button class="calc-btn calc-btn-sci" data-action="const" data-const="pi">π</button>
    <button class="calc-btn calc-btn-sci" data-action="const" data-const="e">e</button>
    <button class="calc-btn calc-btn-func" data-action="paren">(</button>
    <button class="calc-btn calc-btn-func" data-action="paren">)</button>
    <button class="calc-btn calc-btn-func" data-action="percent">%</button>
    <button class="calc-btn calc-btn-func" data-action="ac">AC</button>

    <button class="calc-btn calc-btn-sci" data-action="func" data-func="sin">sin</button>
    <button class="calc-btn calc-btn-sci" data-action="func" data-func="cos">cos</button>
    <button class="calc-btn calc-btn-sci" data-action="func" data-func="tan">tan</button>
    <button class="calc-btn" data-action="digit">7</button>
    <button class="calc-btn" data-action="digit">8</button>
    <button class="calc-btn" data-action="digit">9</button>
    <button class="calc-btn calc-btn-func" data-action="op" data-op="/">÷</button>

    <button class="calc-btn calc-btn-sci" data-action="func" data-func="log">log</button>
    <button class="calc-btn calc-btn-sci" data-action="func" data-func="ln">ln</button>
    <button class="calc-btn calc-btn-sci" data-action="func" data-func="sqrt">√</button>
    <button class="calc-btn" data-action="digit">4</button>
    <button class="calc-btn" data-action="digit">5</button>
    <button class="calc-btn" data-action="digit">6</button>
    <button class="calc-btn calc-btn-func" data-action="op" data-op="*">×</button>

    <button class="calc-btn calc-btn-sci" data-action="func" data-func="pow2">x²</button>
    <button class="calc-btn calc-btn-sci" data-action="op" data-op="^">^</button>
    <button class="calc-btn calc-btn-sci" data-action="negate">±</button>
    <button class="calc-btn" data-action="digit">1</button>
    <button class="calc-btn" data-action="digit">2</button>
    <button class="calc-btn" data-action="digit">3</button>
    <button class="calc-btn calc-btn-func" data-action="op" data-op="-">−</button>

    <button class="calc-btn calc-btn-sci" data-action="func" data-func="abs">|x|</button>
    <button class="calc-btn calc-btn-sci" data-action="ans">Ans</button>
    <button class="calc-btn" data-action="digit" style="grid-column: span 2;">0</button>
    <button class="calc-btn" data-action="digit">.</button>
    <button class="calc-btn calc-btn-equals" data-action="equals">=</button>
    <button class="calc-btn calc-btn-func" data-action="op" data-op="+">+</button>
  </div>
</calculator-card>

<style is:global>
  calculator-card.calculator-card {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--button-border);
    border-radius: 1.25rem;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(12px);
    overflow: hidden;
    position: relative;
  }
  calculator-card.calculator-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, #4285F4, #7C3AED);
  }
  .calculator-card .calc-header { margin-bottom: 0.75rem; }
  .calculator-card .calc-display-row {
    background: var(--button-bg);
    border: 1px solid var(--button-border);
    border-radius: 0.75rem;
    padding: 0.5rem 1rem 0.75rem;
    margin-bottom: 0.75rem;
    min-height: 4.5rem;
  }
  .calculator-card .calc-expression {
    text-align: right;
    font-size: 0.85rem;
    color: var(--text-muted);
    min-height: 1.2rem;
    word-break: break-all;
    margin-bottom: 0.15rem;
    opacity: 0.7;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .calculator-card .calc-display {
    text-align: right;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-color);
    word-break: break-all;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  .calculator-card .calc-main-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.35rem;
  }
  .calculator-card .calc-btn {
    padding: 0.6rem 0.25rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-color);
    background: var(--button-bg);
    border: 1px solid var(--button-border);
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.4rem;
  }
  .calculator-card .calc-btn:hover {
    background: var(--button-hover);
    border-color: var(--search-border);
  }
  .calculator-card .calc-btn:active { transform: scale(0.96); }
  .calculator-card .calc-btn-sci {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .calculator-card .calc-btn-sci:hover { color: var(--link-color); }
  .calculator-card .calc-btn-sci.active-deg {
    color: var(--link-color);
    border-color: var(--link-color);
    font-weight: 700;
  }
  .calculator-card .calc-btn-func { color: var(--link-color); }
  .calculator-card .calc-btn-equals {
    background: linear-gradient(135deg, #4285F4, #7C3AED);
    color: white;
    border-color: transparent;
  }
  .calculator-card .calc-btn-equals:hover {
    background: linear-gradient(135deg, #3367D6, #6B21A8);
  }
  @media (max-width: 560px) {
    .calculator-card .calc-main-grid { gap: 0.25rem; }
    .calculator-card .calc-btn { font-size: 0.8rem; padding: 0.5rem 0.15rem; min-height: 2.1rem; }
    .calculator-card .calc-btn-sci { font-size: 0.68rem; }
    .calculator-card .calc-display { font-size: 1.4rem; }
    .calculator-card { padding: 1rem; }
  }
</style>

<script>
  const OP_MAP: Record<string, string> = { '÷': '/', '×': '*', '−': '-' };

  function safeEval(expr: string, useDeg: boolean) {
    try {
      let e = expr
        .replace(/π/g, '(' + Math.PI + ')')
        .replace(/\bpi\b/gi, '(' + Math.PI + ')')
        .replace(/\be\b/g, '(' + Math.E + ')')
        .replace(/\^/g, '**');

      const funcRe = /\b(sin|cos|tan|log|ln|sqrt|abs)\s*\(/g;
      e = e.replace(funcRe, function(_, fn) {
        if (fn === 'sqrt') return 'Math.sqrt(';
        if (fn === 'abs') return 'Math.abs(';
        if (fn === 'log') return 'Math.log10(';
        if (fn === 'ln') return 'Math.log(';
        if (fn === 'sin') return useDeg ? '__sd(' : 'Math.sin(';
        if (fn === 'cos') return useDeg ? '__cd(' : 'Math.cos(';
        if (fn === 'tan') return useDeg ? '__td(' : 'Math.tan(';
        return fn + '(';
      });

      const __sd = (x: number) => Math.sin(x * Math.PI / 180);
      const __cd = (x: number) => Math.cos(x * Math.PI / 180);
      const __td = (x: number) => Math.tan(x * Math.PI / 180);

      const result = new Function('"use strict"; var __sd=' + __sd.toString() + ',__cd=' + __cd.toString() + ',__td=' + __td.toString() + '; return (' + e + ')')();
      if (typeof result !== 'number' || !isFinite(result)) return 'Error';
      if (Number.isInteger(result)) return result.toString();
      return parseFloat(result.toPrecision(12)).toString();
    } catch { return 'Error'; }
  }

  class CalculatorCard extends HTMLElement {
    private display: HTMLElement | null;
    private exprLine: HTMLElement | null;
    private degBtn: HTMLElement | null;
    private current: string = '0';
    private resetOnNext: boolean = false;
    private useDeg: boolean = true;
    private lastExpr: string = '';
    private lastAns: string = '0';

    constructor() {
      super();
      this.display = this.querySelector('.calc-display');
      this.exprLine = this.querySelector('.calc-expression');
      this.degBtn = this.querySelector('#calc-deg-btn');
    }

    connectedCallback() {
      if (!this.display) return;

      const initial = this.display.textContent?.trim() || '0';
      if (initial !== 'Error' && !isNaN(parseFloat(initial))) {
        this.current = initial;
      }

      this.querySelectorAll('.calc-btn').forEach(btn => {
        btn.addEventListener('click', () => this.handleButtonClick(btn as HTMLButtonElement));
      });
    }

    handleButtonClick(btn: HTMLButtonElement) {
      const action = btn.dataset.action;
      const val = btn.textContent?.trim() || '';
      let opVal = btn.dataset.op || val;
      if (OP_MAP[opVal]) opVal = OP_MAP[opVal];

      if (this.current === 'Error' && action !== 'ac') this.current = '0';

      if (action === 'digit') {
        if (this.resetOnNext) { this.current = val; this.resetOnNext = false; this.showExpr(''); }
        else this.current = this.current === '0' ? val : this.current + val;
      } else if (action === 'op') {
        if (this.current === 'Error') return;
        if (this.resetOnNext) this.resetOnNext = false;
        const last = this.current.slice(-1);
        if (['+', '-', '*', '/', '^'].includes(last)) {
          this.current = this.current.slice(0, -1) + opVal;
        } else {
          this.current += opVal;
        }
        this.showExpr('');
      } else if (action === 'paren') {
        if (this.resetOnNext) { this.current = val; this.resetOnNext = false; this.showExpr(''); }
        else this.current = this.current === '0' ? val : this.current + val;
      } else if (action === 'func') {
        const fn = btn.dataset.func;
        if (fn) this.applyFunc(fn);
      } else if (action === 'const') {
        const c = btn.dataset.const;
        if (c === 'pi') {
          if (this.resetOnNext) { this.current = 'π'; this.resetOnNext = false; }
          else this.current = this.current === '0' ? 'π' : this.current + 'π';
        } else if (c === 'e') {
          if (this.resetOnNext) { this.current = 'e'; this.resetOnNext = false; }
          else this.current = this.current === '0' ? 'e' : this.current + 'e';
        }
        this.showExpr('');
      } else if (action === 'percent') {
        if (this.resetOnNext) this.resetOnNext = false;
        this.current = '(' + this.current + ')/100';
        this.evaluate();
      } else if (action === 'negate') {
        if (this.current !== '0' && this.current !== 'Error') {
          if (this.current.startsWith('-')) this.current = this.current.slice(1);
          else this.current = '-' + this.current;
        }
      } else if (action === 'deg') {
        this.useDeg = !this.useDeg;
        if (this.degBtn) {
          this.degBtn.textContent = this.useDeg ? 'DEG' : 'RAD';
          this.degBtn.classList.toggle('active-deg', this.useDeg);
        }
      } else if (action === 'ans') {
        if (this.resetOnNext) { this.current = this.lastAns; this.resetOnNext = false; }
        else this.current = this.current === '0' ? this.lastAns : this.current + this.lastAns;
        this.showExpr('');
      } else if (action === 'ac') {
        this.current = '0';
        this.resetOnNext = false;
        this.showExpr('');
      } else if (action === 'equals') {
        this.evaluate();
      }
      this.updateDisplay();
    }

    updateDisplay() {
      if (this.display) {
        this.display.textContent = this.current || '0';
      }
    }

    showExpr(txt: string) {
      if (this.exprLine) {
        this.exprLine.textContent = txt || '';
      }
    }

    evaluate() {
      this.lastExpr = this.current;
      this.showExpr(this.lastExpr + ' =');
      const result = safeEval(this.current, this.useDeg);
      this.current = result;
      this.lastAns = result;
      this.resetOnNext = true;
      this.updateDisplay();
    }

    applyFunc(fn: string) {
      if (fn === 'pow2') {
        if (this.resetOnNext) { this.current = '(' + this.current + ')^2'; this.resetOnNext = false; }
        else this.current = this.current === '0' ? '(0)^2' : '(' + this.current + ')^2';
        this.evaluate();
        return;
      }
      if (this.resetOnNext) { this.current = fn + '(' + this.current + ')'; this.resetOnNext = false; }
      else this.current = this.current === '0' ? fn + '(0)' : fn + '(' + this.current + ')';
      this.evaluate();
    }
  }

  customElements.define('calculator-card', CalculatorCard);
</script>
