---
import { getTranslation } from '../i18n/translations';

interface Props {
  q: string;
  lang: string;
}

const { q, lang } = Astro.props;
const t = getTranslation(lang);

const MONTHS_ES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const MONTHS_EN = ['january','february','march','april','may','june','july','august','september','october','november','december'];

const CAL_KEYWORD = /^(?:calendario|calendar|cal)$/i;
const MONTH_YEAR = new RegExp(
  `^(?:calendario|calendar|cal)?\\s*(?:(${MONTHS_ES.join('|')}|${MONTHS_EN.join('|')}))?\\s*(\\d{4})?$`,
  'i'
);

const match = q.trim().match(MONTH_YEAR);
if (!match || (!match[1] && !match[2] && !CAL_KEYWORD.test(q.trim()))) return;

const now = new Date();
let month = now.getMonth();
let year = now.getFullYear();

if (match[1]) {
  const rawMonth = match[1].toLowerCase();
  let idx = MONTHS_EN.indexOf(rawMonth);
  if (idx === -1) idx = MONTHS_ES.indexOf(rawMonth);
  if (idx !== -1) month = idx;
}

if (match[2]) {
  year = parseInt(match[2], 10);
}

function buildCalendar(m: number, yr: number): { weeks: (number | null)[][]; today: number } {
  const firstDay = new Date(yr, m, 1).getDay();
  const daysInMonth = new Date(yr, m + 1, 0).getDate();
  const adjustedFirst = firstDay === 0 ? 7 : firstDay;

  const weeks: (number | null)[][] = [];
  let week: (number | null)[] = [];
  for (let i = 1; i < adjustedFirst; i++) week.push(null);
  for (let d = 1; d <= daysInMonth; d++) {
    week.push(d);
    if (week.length === 7) { weeks.push(week); week = []; }
  }
  while (week.length < 7) week.push(null);
  if (week.some(d => d !== null)) weeks.push(week);

  const today = now.getMonth() === m && now.getFullYear() === yr ? now.getDate() : -1;
  return { weeks, today };
}

const cal = buildCalendar(month, year);

const monthName = new Date(year, month, 1).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { month: 'long' });

const dayNamesES = ['L', 'M', 'X', 'J', 'V', 'S', 'D'];
const dayNamesEN = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
const dayNames = lang === 'es' ? dayNamesES : dayNamesEN;
---

<calendar-card class="calendar-card animate-fade-in-up" data-lang={lang === 'es' ? 'es' : 'en'}>
  <div class="cal-left">
    <div class="cal-header">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--link-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      <span>{t.calendar_title}</span>
    </div>

    <div class="cal-control-group">
      <label>{lang === 'es' ? 'MES' : 'MONTH'}</label>
      <div class="cal-select-wrapper">
        <div class="cal-select-mock">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <span class="cal-sidebar-month">{monthName}</span>
          <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
        <select class="cal-real-select cal-month-select">
          {(lang === 'es' ? MONTHS_ES : MONTHS_EN).map((mName, i) => (
             <option value={i} selected={i === month}>{mName.charAt(0).toUpperCase() + mName.slice(1)}</option>
          ))}
        </select>
      </div>
    </div>

    <div class="cal-control-group">
      <label>{lang === 'es' ? 'AÑO' : 'YEAR'}</label>
      <div class="cal-select-wrapper">
        <div class="cal-select-mock">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <span class="cal-sidebar-year">{year}</span>
          <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
        <select class="cal-real-select cal-year-select">
          {Array.from({length: 21}, (_, i) => year - 10 + i).map(y => (
             <option value={y} selected={y === year}>{y}</option>
          ))}
        </select>
      </div>
    </div>

    <div class="cal-actions">
      <button class="cal-nav-btn" data-dir="prevYear" title={t.calendar_yearPrev || 'Previous year'}>«</button>
      <button class="cal-nav-btn" data-dir="prev" title={t.calendar_prev || 'Previous month'}>‹</button>
      <button class="cal-nav-btn" data-dir="next" title={t.calendar_next || 'Next month'}>›</button>
      <button class="cal-nav-btn" data-dir="nextYear" title={t.calendar_yearNext || 'Next year'}>»</button>
    </div>
  </div>

  <div class="cal-right">
    <table class="cal-table">
      <thead>
        <tr>
          {dayNames.map(d => <th class="cal-day-header">{d}</th>)}
        </tr>
      </thead>
      <tbody id="cal-tbody">
        {cal.weeks.map(week => (
          <tr>
            {week.map(d => d !== null ? (
              <td class:list={['cal-day', d === cal.today ? 'cal-today' : '']} data-day={d}>
                <div class="cal-day-box">
                  <span class="cal-day-number">{d}</span>
                  <div class="cal-note-indicator hidden"></div>
                </div>
              </td>
            ) : (
              <td class="cal-day cal-empty"></td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>

    <!-- Note Editor Panel -->
    <div class="cal-note-editor hidden">
      <div class="cal-note-header">
        <span class="cal-selected-date"></span>
        <button class="cal-close-note">×</button>
      </div>
      <textarea class="cal-note-input" placeholder={lang === 'es' ? 'Añadir nota o evento...' : 'Add note or event...'}></textarea>
      <div class="cal-note-footer">
        <button class="cal-save-note">{lang === 'es' ? 'Guardar' : 'Save'}</button>
      </div>
    </div>
  </div>
</calendar-card>

<style is:global>
  calendar-card.calendar-card {
    background: var(--card-bg);
    border: 1px solid var(--button-border);
    border-radius: 1.25rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(12px);
    overflow: hidden;
    position: relative;
    display: flex;
    gap: 1.5rem;
    min-height: 380px;
  }
  calendar-card.calendar-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, #EA4335, #FBBC05);
  }
  .calendar-card .cal-left {
    display: flex;
    flex-direction: column;
    min-width: 140px;
    border-right: 1px solid var(--button-border);
    padding-right: 1.5rem;
  }
  .calendar-card .cal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .calendar-card .cal-header span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-color);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .calendar-card .cal-control-group {
    margin-bottom: 1.5rem;
  }
  .calendar-card .cal-control-group label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .calendar-card .cal-select-wrapper {
    position: relative;
    cursor: pointer;
  }
  .calendar-card .cal-real-select {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
  }
  .calendar-card .cal-select-mock {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--button-bg);
    border: 1px solid var(--button-border);
    padding: 0.5rem 0.6rem;
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-color);
  }
  .calendar-card .cal-select-mock svg.chevron {
    margin-left: auto;
    opacity: 0.5;
  }
  .calendar-card .cal-select-mock span {
    text-transform: capitalize;
  }
  .calendar-card .cal-actions {
    display: flex;
    gap: 0.4rem;
    margin-top: auto;
  }
  .calendar-card .cal-nav-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--button-bg);
    border: 1px solid var(--button-border);
    color: var(--text-color);
    height: 2rem;
    border-radius: 0.4rem;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  .calendar-card .cal-nav-btn:hover {
    background: var(--button-hover);
    color: var(--link-color);
    border-color: var(--link-color);
  }
  .calendar-card .cal-right {
    flex: 1;
    position: relative;
  }
  .calendar-card .cal-table {
    width: 100%;
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 4px;
  }
  .calendar-card .cal-day-header {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    padding: 0.4rem 0 1rem 0;
  }
  .calendar-card .cal-day {
    text-align: center;
    padding: 0;
  }
  .calendar-card .cal-day-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 0.5rem;
    background: var(--button-bg);
    border: 1px solid transparent;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-color);
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
  }
  .calendar-card .cal-day:not(.cal-empty):hover .cal-day-box {
    background: var(--button-hover);
    border-color: var(--button-border);
  }
  .calendar-card .cal-empty .cal-day-box {
    background: transparent;
    border-color: transparent;
    cursor: default;
  }
  .calendar-card .cal-today .cal-day-box {
    background: var(--link-color);
    color: white;
    font-weight: 700;
  }
  .calendar-card .cal-note-indicator {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--link-color);
    position: absolute;
    bottom: 4px;
  }
  .calendar-card .cal-today .cal-note-indicator {
    background: white;
  }
  
  /* Note Editor */
  .cal-note-editor {
    position: absolute;
    top: 1rem;
    right: 1rem;
    bottom: 1rem;
    left: 170px;
    background: var(--card-bg);
    border: 1px solid var(--button-border);
    border-radius: 1rem;
    z-index: 10;
    display: none;
    flex-direction: column;
    padding: 1rem;
    box-shadow: -5px 0 15px rgba(0,0,0,0.1);
    animation: slideIn 0.2s ease-out;
  }
  .cal-note-editor.active {
    display: flex;
  }
  @keyframes slideIn { from { opacity: 0; transform: translateX(10px); } to { opacity: 1; transform: translateX(0); } }
  
  .cal-note-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
  .cal-selected-date { font-weight: 700; font-size: 0.9rem; color: var(--text-color); text-transform: capitalize; }
  .cal-close-note { background: none; border: none; font-size: 1.5rem; color: var(--text-muted); cursor: pointer; line-height: 1; }
  .cal-note-input {
    flex: 1;
    background: var(--bg-color);
    border: 1px solid var(--button-border);
    border-radius: 0.5rem;
    padding: 0.75rem;
    color: var(--text-color);
    font-size: 0.85rem;
    resize: none;
    outline: none;
  }
  .cal-note-input:focus { border-color: var(--link-color); }
  .cal-note-footer { margin-top: 0.75rem; display: flex; justify-content: flex-end; }
  .cal-save-note {
    background: var(--link-color);
    color: white;
    border: none;
    padding: 0.4rem 1rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.8rem;
    cursor: pointer;
  }
  
  @media (max-width: 640px) {
    calendar-card.calendar-card {
      flex-direction: row;
      padding: 1rem;
      gap: 0.75rem;
    }
    .calendar-card .cal-left {
      min-width: 100px;
      padding-right: 0.75rem;
      border-right: 1px solid var(--button-border);
      border-bottom: none;
      padding-bottom: 0;
    }
    .calendar-card .cal-select-mock {
      padding: 0.3rem 0.4rem;
      font-size: 0.75rem;
      gap: 0.2rem;
    }
    .calendar-card .cal-select-mock svg {
      width: 12px;
      height: 12px;
    }
    .calendar-card .cal-nav-btn {
      height: 1.6rem;
      font-size: 0.8rem;
    }
    .calendar-card .cal-day-box { font-size: 0.8rem; }
    .calendar-card .cal-day-header {
      font-size: 0.65rem;
      padding: 0.2rem 0 0.5rem 0;
    }
    .calendar-card .cal-header {
      margin-bottom: 1rem;
      gap: 0.3rem;
    }
    .calendar-card .cal-header span {
      font-size: 0.75rem;
    }
    .calendar-card .cal-header svg {
      width: 14px;
      height: 14px;
    }
    .calendar-card .cal-control-group {
      margin-bottom: 1rem;
    }
    .calendar-card .cal-control-group label {
      font-size: 0.6rem;
      margin-bottom: 0.4rem;
    }
    .calendar-card .cal-table {
      border-spacing: 2px;
    }
    .calendar-card .cal-actions {
      margin-top: auto;
    }
    .cal-note-editor { left: 1rem; top: 3.5rem; }
  }
</style>

<script>
  class CalendarCard extends HTMLElement {
    private month: number;
    private year: number;
    private lang: string;
    private selectedDay: number | null = null;
    private notes: Record<string, string> = {};

    constructor() {
      super();
      this.lang = this.dataset.lang === 'es' ? 'es' : 'en';
      this.month = new Date().getMonth();
      this.year = new Date().getFullYear();
      this.loadNotes();
    }

    connectedCallback() {
      const monthEl = this.querySelector('.cal-sidebar-month');
      const yearEl = this.querySelector('.cal-sidebar-year');
      if (monthEl) {
        const mName = monthEl.textContent?.toLowerCase() || '';
        const MONTHS_ES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
        const MONTHS_EN = ['january','february','march','april','may','june','july','august','september','october','november','december'];
        let idx = MONTHS_EN.indexOf(mName);
        if (idx === -1) idx = MONTHS_ES.indexOf(mName);
        if (idx !== -1) this.month = idx;
      }
      if (yearEl) {
        const y = parseInt(yearEl.textContent || '', 10);
        if (!isNaN(y)) this.year = y;
      }

      this.setupListeners();
      this.renderCalendar();
    }

    setupListeners() {
      this.querySelectorAll('.cal-nav-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const dir = (btn as HTMLElement).dataset.dir;
          if (dir === 'prev') { this.month--; if (this.month < 0) { this.month = 11; this.year--; } }
          else if (dir === 'next') { this.month++; if (this.month > 11) { this.month = 0; this.year++; } }
          else if (dir === 'prevYear') { this.year--; }
          else if (dir === 'nextYear') { this.year++; }
          this.closeEditor();
          this.renderCalendar();
        });
      });

      this.querySelector('.cal-month-select')?.addEventListener('change', (e) => {
        this.month = parseInt((e.target as HTMLSelectElement).value, 10);
        this.closeEditor();
        this.renderCalendar();
      });

      this.querySelector('.cal-year-select')?.addEventListener('change', (e) => {
        this.year = parseInt((e.target as HTMLSelectElement).value, 10);
        this.closeEditor();
        this.renderCalendar();
      });

      this.querySelector('.cal-close-note')?.addEventListener('click', () => this.closeEditor());
      this.querySelector('.cal-save-note')?.addEventListener('click', () => this.saveNote());
    }

    loadNotes() {
      const stored = localStorage.getItem('suvy_calendar_notes');
      if (stored) {
        try { this.notes = JSON.parse(stored); } catch (e) { this.notes = {}; }
      }
    }

    saveNote() {
      if (this.selectedDay === null) return;
      const input = this.querySelector('.cal-note-input') as HTMLTextAreaElement;
      const dateKey = `${this.year}-${String(this.month + 1).padStart(2, '0')}-${String(this.selectedDay).padStart(2, '0')}`;
      
      const content = input.value.trim();
      if (content) {
        this.notes[dateKey] = content;
      } else {
        delete this.notes[dateKey];
      }
      
      localStorage.setItem('suvy_calendar_notes', JSON.stringify(this.notes));
      this.closeEditor();
      this.renderCalendar();
    }

    openEditor(day: number) {
      this.selectedDay = day;
      const editor = this.querySelector('.cal-note-editor');
      const dateLabel = this.querySelector('.cal-selected-date');
      const input = this.querySelector('.cal-note-input') as HTMLTextAreaElement;
      
      if (editor && dateLabel && input) {
        const date = new Date(this.year, this.month, day);
        dateLabel.textContent = date.toLocaleDateString(this.lang === 'es' ? 'es-ES' : 'en-US', { day: 'numeric', month: 'long', year: 'numeric' });
        
        const dateKey = `${this.year}-${String(this.month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        input.value = this.notes[dateKey] || '';
        
        editor.classList.add('active');
        input.focus();
      }
    }

    closeEditor() {
      this.selectedDay = null;
      this.querySelector('.cal-note-editor')?.classList.remove('active');
    }

    renderCalendar() {
      const daysInMonth = new Date(this.year, this.month + 1, 0).getDate();
      const firstDay = new Date(this.year, this.month, 1).getDay();
      const adjustedFirst = firstDay === 0 ? 7 : firstDay;

      const now = new Date();
      const isCurrentMonth = now.getMonth() === this.month && now.getFullYear() === this.year;
      const today = isCurrentMonth ? now.getDate() : -1;

      const monthEl = this.querySelector('.cal-sidebar-month');
      const yearEl = this.querySelector('.cal-sidebar-year');
      if (monthEl) monthEl.textContent = new Date(this.year, this.month, 1).toLocaleDateString(this.lang === 'es' ? 'es-ES' : 'en-US', { month: 'long' });
      if (yearEl) yearEl.textContent = this.year.toString();

      const tbody = this.querySelector('#cal-tbody');
      if (!tbody) return;

      tbody.innerHTML = '';
      let day = 1;
      for (let i = 0; i < 6; i++) {
        const tr = document.createElement('tr');
        for (let j = 1; j <= 7; j++) {
          const td = document.createElement('td');
          td.className = 'cal-day';
          
          const idx = i * 7 + j;
          if (idx < adjustedFirst || day > daysInMonth) {
            td.classList.add('cal-empty');
          } else {
            const currentDay = day;
            const dateKey = `${this.year}-${String(this.month + 1).padStart(2, '0')}-${String(currentDay).padStart(2, '0')}`;
            const hasNote = !!this.notes[dateKey];
            
            td.dataset.day = currentDay.toString();
            if (currentDay === today) td.classList.add('cal-today');
            
            td.innerHTML = `
              <div class="cal-day-box">
                <span class="cal-day-number">${currentDay}</span>
                <div class="cal-note-indicator ${hasNote ? '' : 'hidden'}"></div>
              </div>
            `;
            
            td.addEventListener('click', () => this.openEditor(currentDay));
            day++;
          }
          tr.appendChild(td);
        }
        tbody.appendChild(tr);
        if (day > daysInMonth) break;
      }
    }
  }
  customElements.define('calendar-card', CalendarCard);
</script>
