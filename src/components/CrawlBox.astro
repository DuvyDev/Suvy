---
import { getTranslation } from '../i18n/translations';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
---

<crawl-box class="w-full">
  <div class="crawl-box-inner p-6 rounded-2xl border border-[var(--search-border)] backdrop-blur-sm">
    <h2 class="text-base font-semibold text-[var(--text-color)] mb-2 flex items-center gap-2">
      <svg class="w-5 h-5 text-[var(--link-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656-1.1 1.1" />
      </svg>
      {t.addUrlTitle}
    </h2>
    <p class="text-sm text-[var(--text-muted)] mb-4">{t.addUrlDesc}</p>
    <div class="flex gap-3 min-w-0">
      <input 
        type="url" 
        id="crawl-url"
        placeholder="https://example.com"
        class="min-w-0 flex-1 bg-[var(--button-bg)] border border-[var(--button-border)] rounded-xl px-4 py-2.5 text-sm text-[var(--text-color)] outline-none focus:border-[var(--link-color)] transition-colors"
        data-msg-empty={t.enterValidUrl}
        data-msg-protocol={t.urlMustStartWith}
      />
      <button id="crawl-btn" class="bg-[var(--button-bg)] hover:bg-[var(--button-hover)] border border-[var(--button-border)] text-[var(--button-text)] px-3 py-2.5 rounded-xl font-medium text-sm transition-all duration-300 cursor-pointer flex items-center gap-1.5 whitespace-nowrap shrink-0"
        data-msg-sending={t.sending}
        data-msg-success={t.urlQueued}
        data-msg-success-skip={t.urlQueuedWithSkip}
        data-msg-error={t.errorQueueing}
        data-msg-crawler-down={t.crawlerNotRunning}
      >
        <span id="crawl-btn-text">{t.enqueue}</span>
        <svg id="crawl-btn-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </button>
    </div>
    <p id="crawl-status" class="mt-3 text-sm font-medium hidden"></p>
  </div>
</crawl-box>

<style is:global>
  crawl-box {
    display: block;
  }
  .crawl-box-inner {
    background: var(--card-bg);
    box-shadow: var(--search-shadow);
  }
</style>

<script>
  class CrawlBox extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      const input = this.querySelector('#crawl-url') as HTMLInputElement;
      const btn = this.querySelector('#crawl-btn') as HTMLButtonElement;
      const status = this.querySelector('#crawl-status') as HTMLElement;
      if (!input || !btn || !status) return;

      const msgs = {
        empty: input.getAttribute('data-msg-empty'),
        protocol: input.getAttribute('data-msg-protocol'),
        sending: btn.getAttribute('data-msg-sending'),
        success: btn.getAttribute('data-msg-success'),
        successSkip: btn.getAttribute('data-msg-success-skip'),
        error: btn.getAttribute('data-msg-error'),
        crawlerDown: btn.getAttribute('data-msg-crawler-down'),
      };

      const setStatus = (msg: string | null, type: string) => {
        status.textContent = msg;
        status.classList.remove('hidden', 'text-emerald-500', 'text-red-500', 'text-[var(--text-muted)]');
        if (type === 'success') status.classList.add('text-emerald-500');
        else if (type === 'error') status.classList.add('text-red-500');
        else status.classList.add('text-[var(--text-muted)]');
      };

      const submitUrl = async () => {
        const url = input.value.trim();
        if (!url) { setStatus(msgs.empty, 'error'); return; }
        if (!url.startsWith('http://') && !url.startsWith('https://')) {
          setStatus(msgs.protocol, 'error'); return;
        }
        btn.disabled = true;
        btn.classList.add('opacity-60', 'cursor-not-allowed');
        setStatus(msgs.sending, 'info');
        try {
          const res = await fetch('/api/crawl', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ urls: [url], force: true }),
          });
          const data = await res.json();
          if (res.ok && data.success) {
            const msg = data.skipped > 0
              ? msgs.successSkip?.replace('{queued}', data.queued).replace('{skipped}', data.skipped)
              : msgs.success;
            setStatus(msg || null, 'success');
            input.value = '';
          } else {
            setStatus(data.error || msgs.error, 'error');
          }
        } catch (e) {
          setStatus(msgs.crawlerDown, 'error');
        } finally {
          btn.disabled = false;
          btn.classList.remove('opacity-60', 'cursor-not-allowed');
        }
      };

      btn.addEventListener('click', submitUrl);
      input.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitUrl(); });
    }
  }

  customElements.define('crawl-box', CrawlBox);
</script>
