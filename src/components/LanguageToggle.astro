---
const langCookie = Astro.cookies.get('lang')?.value;
const currentLang = langCookie === 'es' ? 'es' : 'en';
---

<div class="relative flex items-center ml-2">
  <select id="lang-select" class="appearance-none bg-transparent text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-color)] cursor-pointer outline-none pr-4 pl-1 py-1 transition-colors">
    <option value="es" selected={currentLang === 'es'}>ES</option>
    <option value="en" selected={currentLang === 'en'}>EN</option>
  </select>
  <!-- Small custom chevron to replace native one for a cleaner look -->
  <svg class="w-3 h-3 text-[var(--text-muted)] absolute right-0 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
  </svg>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const select = document.getElementById('lang-select');
    select?.addEventListener('change', (e) => {
      const targetLang = (e.target as HTMLSelectElement).value;
      // Set cookie for Astro SSR
      document.cookie = `lang=${targetLang}; path=/; max-age=31536000`;
      // Reload page to apply changes
      window.location.reload();
    });
  });
</script>
