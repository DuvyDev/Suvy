---
import { detectUserAgentQuery, parseUserAgent } from '../lib/useragent';
import { getTranslation } from '../i18n/translations';

interface Props {
  q: string;
  lang: string;
}

const { q, lang } = Astro.props;
const t = getTranslation(lang);

if (!detectUserAgentQuery(q)) return;

const ua = Astro.request.headers.get('user-agent') || '';
let ip = Astro.request.headers.get('cf-connecting-ip') || null;
if (!ip) {
  ip = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || null;
}
if (!ip) {
  ip = Astro.request.headers.get('x-real-ip') || null;
}
if (!ip) {
  ip = Astro.clientAddress || null;
}

const info = parseUserAgent(ua, ip || (lang === 'es' ? 'No detectada' : 'Not detected'));

const browserColor = info.browser === 'Chrome' ? '#4285F4'
  : info.browser === 'Firefox' ? '#FF7139'
  : info.browser === 'Safari' ? '#007AFF'
  : info.browser === 'Edge' ? '#0078D7'
  : info.browser === 'Opera' ? '#FF1B2D'
  : 'var(--link-color)';

const osColor = info.os === 'Windows' ? '#0078D4'
  : info.os === 'macOS' ? '#333'
  : info.os === 'Linux' ? '#FCC624'
  : info.os === 'Android' ? '#3DDC84'
  : info.os === 'iOS' ? '#333'
  : info.os === 'Chrome OS' ? '#4285F4'
  : 'var(--link-color)';

const deviceColor = info.device === 'Mobile' ? '#EA4335'
  : info.device === 'Tablet' ? '#7C3AED'
  : '#34A853';

const deviceLabel = info.device === 'Mobile' ? t.ua_mobile
  : info.device === 'Tablet' ? t.ua_tablet
  : t.ua_desktop;
---

<user-agent-card class="ua-card animate-fade-in-up">
  <div class="ua-header">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--link-color)]">
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
        <line x1="8" y1="21" x2="16" y2="21"/>
        <line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
      <span class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wide">{t.ua_title}</span>
    </div>
  </div>

  <div class="ua-grid">
    <div class="ua-item">
      <div class="ua-icon" style={`color: ${browserColor}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
      </div>
      <div class="ua-info">
        <span class="ua-label">{t.ua_browser}</span>
        <span class="ua-value">{info.browser}{info.browserVersion ? ` ${info.browserVersion}` : ''}</span>
      </div>
    </div>

    <div class="ua-item">
      <div class="ua-icon" style={`color: ${osColor}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <div class="ua-info">
        <span class="ua-label">{t.ua_os}</span>
        <span class="ua-value">{info.os}{info.osVersion ? ` ${info.osVersion}` : ''}</span>
      </div>
    </div>

    <div class="ua-item">
      <div class="ua-icon" style="color: #34A853">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
          <path d="M12 11v3"/>
          <path d="M21 12a9 9 0 11-6.219-8.56"/>
        </svg>
      </div>
      <div class="ua-info">
        <span class="ua-label">{t.ua_ip}</span>
        <span class="ua-value ua-ip-value">{info.ip}</span>
      </div>
    </div>
  </div>

  <div class="ua-raw">
    <span class="ua-raw-label">User-Agent</span>
    <button class="ua-copy-btn" id="ua-copy-btn" data-raw={info.raw} title={t.copy}>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
      </svg>
    </button>
    <span class="ua-raw-text">{info.raw}</span>
  </div>
</user-agent-card>

<style is:global>
  user-agent-card.ua-card {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--button-border);
    border-radius: 1.25rem;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(12px);
    overflow: hidden;
    position: relative;
  }
  user-agent-card.ua-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, #7C3AED, #EC4899);
  }
  .ua-card .ua-header { margin-bottom: 1rem; }
  .ua-card .ua-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .ua-card .ua-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.65rem 0.75rem;
    background: var(--button-bg);
    border: 1px solid var(--button-border);
    border-radius: 0.65rem;
  }
  .ua-card .ua-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ua-card .ua-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .ua-card .ua-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .ua-card .ua-value {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-color);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ua-card .ua-ip-value {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.85rem;
    letter-spacing: -0.02em;
  }
  .ua-card .ua-raw {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--button-bg);
    border: 1px solid var(--button-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .ua-card .ua-raw-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .ua-card .ua-raw-text {
    font-size: 0.72rem;
    color: var(--text-muted);
    opacity: 0.7;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  }
  .ua-card .ua-copy-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 0.35rem;
    background: transparent;
    border: 1px solid var(--button-border);
    cursor: pointer;
    color: var(--text-muted);
    transition: all 0.15s;
  }
  .ua-card .ua-copy-btn:hover {
    background: var(--button-hover);
    color: var(--link-color);
  }
  @media (max-width: 480px) {
    .ua-card .ua-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  class UserAgentCard extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      const btn = this.querySelector('#ua-copy-btn') as HTMLButtonElement;
      if (!btn) return;

      btn.addEventListener('click', () => {
        const raw = btn.dataset.raw || '';
        navigator.clipboard.writeText(raw).then(() => {
          const originalHTML = btn.innerHTML;
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(() => {
            btn.innerHTML = originalHTML;
          }, 2000);
        });
      });
    }
  }

  customElements.define('user-agent-card', UserAgentCard);
</script>