---
export interface Props {
  query: string;
  lang: string;
}

const { query, lang } = Astro.props;
---

<div class="wiki-card" id="wiki-card" style="display: none;" data-query={query} data-lang={lang}>
  <div class="wiki-header">
    <div class="wiki-icon" style="overflow: hidden; display: flex; align-items: center; justify-content: center;">
      <img id="wiki-favicon" src="" alt="" class="w-10 h-10 rounded-lg" style="object-fit: contain; display: none;" />
    </div>
    <div class="wiki-title-wrap">
      <h3 class="wiki-title" id="wiki-title"></h3>
      <span class="wiki-domain" id="wiki-domain"></span>
    </div>
  </div>
  <p class="wiki-content" id="wiki-content"></p>
  <a id="wiki-link" href="#" class="wiki-link">
    Leer más en Wikipedia
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>

<script>
  const wikiCard = document.getElementById('wiki-card');
  if (wikiCard) {
    const query = wikiCard.getAttribute('data-query');
    const lang = wikiCard.getAttribute('data-lang');
    
    if (query) {
      fetch(`/api/wikipedia?q=${encodeURIComponent(query)}&lang=${encodeURIComponent(lang || 'es')}`)
        .then(r => r.json())
        .then(data => {
          if (data.found && data.result) {
            const titleEl = document.getElementById('wiki-title');
            if (titleEl) titleEl.textContent = data.result.title;
            
            let domain = 'wikipedia.org';
            const domainEl = document.getElementById('wiki-domain');
            try {
              const urlObj = new URL(data.result.url);
              domain = urlObj.hostname;
              if (domainEl) domainEl.textContent = `${urlObj.protocol}//${urlObj.hostname}${urlObj.pathname !== '/' ? urlObj.pathname : ''}`;
            } catch(e) {
              if (domainEl) domainEl.textContent = data.result.url;
            }
            
            const favImg = document.getElementById('wiki-favicon');
            if (favImg && favImg instanceof HTMLImageElement) {
              favImg.src = `https://icons.duckduckgo.com/ip3/${domain}.ico`;
              favImg.style.display = 'block';
              favImg.onerror = () => {
                favImg.src = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
              };
            }
            
            const contentEl = document.getElementById('wiki-content');
            if (contentEl) contentEl.innerHTML = data.result.content;
            
            const link = document.getElementById('wiki-link');
            if (link && link instanceof HTMLAnchorElement) link.href = data.result.url;
            
            wikiCard.style.display = 'block';
            wikiCard.classList.add('animate-fade-in-up');
          }
        })
        .catch(e => console.error('Error fetching wiki:', e));
    }
  }
</script>

<style>
  .wiki-card {
    background: var(--card-bg);
    border: 1px solid var(--search-border);
    border-radius: 1.25rem;
    padding: 1.25rem;
    backdrop-filter: blur(12px);
    box-shadow: var(--search-shadow);
    transition: all 0.3s ease;
  }
  .wiki-card:hover {
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
    border-color: var(--link-color);
  }
  .wiki-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .wiki-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    background: var(--button-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .wiki-title-wrap {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .wiki-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-color);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .wiki-domain {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .wiki-content {
    font-size: 0.9rem;
    color: var(--text-color);
    line-height: 1.6;
    opacity: 0.9;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .wiki-content :global(b),
  .wiki-content :global(strong),
  .wiki-content :global(mark) {
    background: transparent !important;
    color: inherit !important;
    font-weight: 600 !important;
  }
  .wiki-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--link-color);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .wiki-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
</style>