---
import { getTranslation } from '../i18n/translations';

const langCookie = Astro.cookies.get('lang')?.value;
const t = getTranslation(langCookie);

export interface Props {
  query: string;
}

const { query } = Astro.props;
---

<div id="related-searches-container" class="hidden mt-12 mb-16 pt-8 border-t border-[var(--button-border)] max-w-[700px]">
  <h2 class="text-xl font-semibold mb-6 flex items-center gap-2 text-[var(--text-color)]">
    <svg class="w-5 h-5 text-[var(--link-color)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    {t.relatedSearches}
  </h2>
  
  <div id="related-list" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <!-- Items will be injected here -->
  </div>
</div>

<script define:vars={{ query }}>
  async function loadRelated() {
    if (!query) return;
    
    try {
      const response = await fetch(`/api/related?q=${encodeURIComponent(query)}`);
      const data = await response.json();
      
      if (data.related && data.related.length > 0) {
        const container = document.getElementById('related-searches-container');
        const list = document.getElementById('related-list');
        
        if (container && list) {
          list.innerHTML = data.related.map(item => `
            <a href="/search?q=${encodeURIComponent(item)}" class="flex items-center gap-3 p-3 rounded-xl bg-[var(--card-bg)] border border-transparent hover:border-[var(--button-border)] hover:bg-[var(--card-hover)] transition-all group">
              <div class="w-8 h-8 rounded-full bg-[var(--button-bg)] flex items-center justify-center text-[var(--text-muted)] group-hover:text-[var(--link-color)]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              </div>
              <span class="font-medium text-[var(--text-color)] group-hover:text-[var(--link-color)] line-clamp-2">${item}</span>
            </a>
          `).join('');
          
          container.classList.remove('hidden');
        }
      }
    } catch (e) {
      console.error('Error loading related searches:', e);
    }
  }

  // Ultra-lazy loading: wait for the page to be idle
  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(() => loadRelated());
  } else {
    setTimeout(loadRelated, 800);
  }
</script>
